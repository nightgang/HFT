# Environment Configuration Template for HFT Trading System
# Copy this file to .env and populate with your actual values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3001
WS_PORT=3002
NODE_ENV=production

# ============================================================================
# DATABASE CONFIGURATION
# CRITICAL: Change these values for production!
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hft_trading
DB_USER=hft_user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION_USE_SECURE_PASSWORD
DATABASE_URL=postgresql://hft_user:CHANGE_ME_IN_PRODUCTION_USE_SECURE_PASSWORD@localhost:5432/hft_trading
DB_MAX_CONNECTIONS=20

# ============================================================================
# BLOCKCHAIN RPC CONFIGURATION
# ============================================================================
RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here
JUPITER_API_URL=https://quote-api.jup.ag/v4

# ============================================================================
# SECURITY CONFIGURATION (Required for encryption)
# CRITICAL: Generate secure random values!
# ============================================================================
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_JWT_SECRET_64_CHARS_MIN
ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_HEX_KEY_FOR_ENCRYPTION
MASTER_ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_HEX_MASTER_KEY
WEBHOOK_SIGNATURE_SECRET=CHANGE_ME_GENERATE_SECURE_WEBHOOK_SECRET

# ============================================================================
# ADMIN CREDENTIALS (Optional - change for production)
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_PRODUCTION_ADMIN_PASSWORD

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ============================================================================
# CACHE CONFIGURATION (Redis)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# KATANA MODE CONFIGURATION
# ============================================================================
KATANA_ENABLED=true
KATANA_TERMINAL_MODE=false
KATANA_WS_PORT=3003

# Katana Engine
KATANA_MAX_CONCURRENT_TRADES=5
KATANA_MIN_LIQUIDITY_SOL=5
KATANA_MAX_SLIPPAGE=0.3
KATANA_AUTO_BUY_ENABLED=true
KATANA_RISK_PROTECTION_ENABLED=true

# Katana Strategy
KATANA_TP1_PROFIT=200
KATANA_TP1_SELL=30
KATANA_TP2_PROFIT=400
KATANA_TP2_SELL=30
KATANA_TP3_PROFIT=600
KATANA_TP3_SELL=100
KATANA_TRAILING_STOP_ENABLED=true
KATANA_TRAILING_STOP_PERCENT=10
KATANA_STOP_LOSS_ENABLED=true
KATANA_STOP_LOSS_PERCENT=20
KATANA_BREAKEVEN_ENABLED=true
KATANA_BREAKEVEN_PROFIT=50

# Katana Risk
KATANA_RISK_MIN_LIQUIDITY=1
KATANA_RISK_MAX_DEV_PERCENT=20
KATANA_RISK_HONEYPOT_CHECK=true
KATANA_RISK_LIQUIDITY_CHECK=true
KATANA_RISK_DEV_CHECK=true
KATANA_RISK_EMERGENCY_EXIT=true
KATANA_RISK_BLACKLIST=So11111111111111111111111111111112

# Katana Executor
KATANA_EXECUTOR_MAX_RETRIES=3
KATANA_EXECUTOR_RETRY_DELAY=1000
KATANA_EXECUTOR_PRIORITY_FEE_LAMPORTS=100000
KATANA_EXECUTOR_MAX_CONCURRENT=10
KATANA_EXECUTOR_CONFIRMATION_TIMEOUT=30000
KATANA_JITO_ENABLED=false
KATANA_JITO_TIP=10000

# Katana WebSocket
KATANA_WS_HEARTBEAT=30000
KATANA_WS_MAX_CLIENTS=100
