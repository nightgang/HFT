#=============================================================================
# ENVIRONMENT SETUP - COPY TO .env AND CONFIGURE FOR YOUR ENVIRONMENT
#=============================================================================
# NOTE: Never commit actual .env file with real secrets to version control!
#       This is a template showing required environment variables.
#=============================================================================

#=============================================================================
# APPLICATION
#=============================================================================
NODE_ENV=production
APP_NAME=HFT-Trading-System
APP_VERSION=1.0.0
ENABLE_DEBUG=false

#=============================================================================
# SERVER CONFIGURATION
#=============================================================================
BACKEND_PORT=3001
FRONTEND_PORT=5173
AI_SERVICE_PORT=8000

BACKEND_HOST=0.0.0.0
FRONTEND_HOST=0.0.0.0
AI_SERVICE_HOST=0.0.0.0

#=============================================================================
# DATABASE - PostgreSQL
#=============================================================================
# CRITICAL: Use strong credentials and rotate regularly
DB_HOST=localhost
DB_PORT=5432
DB_USER=hft_user
DB_PASSWORD=USE_STRONG_PASSWORD_HERE
DB_NAME=hft_trading
DB_POOL_MIN=5
DB_POOL_MAX=20

# Database SSL (recommended for production)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

#=============================================================================
# REDIS CACHE - Use for session & rate limiting
#=============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=USE_STRONG_PASSWORD_HERE
REDIS_DB=0
REDIS_SSL=true

#=============================================================================
# SOLANA & BLOCKCHAIN
#=============================================================================
# RPC Endpoint - use reliable provider like Mainnet Beta or Alchemy
RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta

# For testing/development only - use public testnet
# RPC_URL=https://api.devnet.solana.com
# SOLANA_CLUSTER=devnet

#=============================================================================
# TRADING SERVICES
#=============================================================================
# Jupiter DEX
JUPITER_API_URL=https://quote-api.jup.ag
JUPITER_SWAP_ENABLED=true

# Raydium
RAYDIUM_API_URL=https://api.raydium.io
RAYDIUM_ENABLED=true

# Orca
ORCA_API_URL=https://www.orca.so/api
ORCA_ENABLED=true

# Meteora
METEORA_API_URL=https://app.meteora.ag/api
METEORA_ENABLED=true

#=============================================================================
# SECURITY & AUTHENTICATION
#=============================================================================
# JWT Secret - CRITICAL: Generate strong random value using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERATE_STRONG_RANDOM_VALUE_HERE_MIN_32_CHARS

JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# API Key for service authentication
API_KEY_SECRET=GENERATE_STRONG_RANDOM_VALUE_HERE
API_KEY_EXPIRY=90d

# CSRF Protection
CSRF_TOKEN_SECRET=GENERATE_STRONG_RANDOM_VALUE_HERE
ENABLE_CSRF=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

#=============================================================================
# ENCRYPTION
#=============================================================================
# For encrypting wallet keys and sensitive data
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GENERATE_STRONG_RANDOM_VALUE_HERE_FOR_AES_256
ENCRYPTION_IV_LENGTH=16

#=============================================================================
# MEV & PROTECTION
#=============================================================================
# Jito MEV Protection (optional but recommended)
JITO_ENABLED=false
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1
JITO_BUNDLE_API_URL=https://bundler.jito.wtf/api/v1

# MEV Detection
MEV_PROTECTION_ENABLED=true
MAX_SLIPPAGE_BPS=50
PRIORITY_FEE_LAMPORTS=100000

#=============================================================================
# KATANA ENGINE (MAIN TRADING ENGINE)
#=============================================================================
KATANA_ENABLED=true
KATANA_TERMINAL_MODE=false
KATANA_USERNAME=admin
KATANA_PASSWORD=password123

# Auto Trade Control
AUTO_TRADE=true

# Position Management
KATANA_MAX_CONCURRENT_TRADES=5
KATANA_MIN_LIQUIDITY_SOL=5
KATANA_MAX_SLIPPAGE=30

# Strategy Parameters
KATANA_TP1_PROFIT=200
KATANA_TP1_SELL=30
KATANA_TP2_PROFIT=400
KATANA_TP2_SELL=30
KATANA_TP3_PROFIT=600
KATANA_TP3_SELL=100

# Stop Loss & Risk Management
KATANA_STOP_LOSS_ENABLED=true
KATANA_STOP_LOSS_PERCENT=20
KATANA_TRAILING_STOP_ENABLED=true
KATANA_TRAILING_STOP_PERCENT=10
KATANA_BREAKEVEN_ENABLED=true
KATANA_BREAKEVEN_PROFIT=50

# Risk Checks
KATANA_RISK_PROTECTION_ENABLED=true
KATANA_RISK_HONEYPOT_CHECK=true
KATANA_RISK_LIQUIDITY_CHECK=true
KATANA_RISK_DEV_CHECK=true
KATANA_RISK_MIN_LIQUIDITY=1
KATANA_RISK_MAX_DEV_PERCENT=20

#=============================================================================
# RISK MANAGEMENT
#=============================================================================
RISK_DAILY_LOSS_LIMIT=-5
RISK_MAX_POSITION_SIZE=1000
RISK_MAX_TRADES_PER_HOUR=100
RISK_MAX_TRADES_PER_DAY=500
RISK_COOLDOWN_PERIOD_MS=30000
RISK_MAX_EXPOSURE_PERCENT=10
RISK_MIN_TRADE_INTERVAL_MS=1000

#=============================================================================
# MONITORING & LOGGING
#=============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILE_SIZE=10mb
LOG_MAX_FILES=10

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana (optional)
GRAFANA_ENABLED=false
GRAFANA_URL=http://localhost:3000

#=============================================================================
# NOTIFICATIONS & ALERTS
#=============================================================================
# Email Notifications
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@gmail.com
EMAIL_SMTP_PASSWORD=YOUR_APP_PASSWORD_HERE
EMAIL_FROM_NAME=HFT Trading System
EMAIL_FROM_ADDRESS=noreply@hft-trading.com

# Alert Thresholds
ALERT_LOSS_PERCENT=-5
ALERT_WIN_PERCENT=50

# Webhook for notifications (optional)
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
WEBHOOK_ENABLED=false

#=============================================================================
# BACKTESTING
#=============================================================================
BACKTEST_CACHE_TTL=3600
BACKTEST_MAX_STRATEGIES=10

#=============================================================================
# AI SERVICE
#=============================================================================
AI_SERVICE_ENABLED=true
AI_MODEL_VERSION=2.0.0
AI_MODEL_PATH=./models/
AI_PREDICTION_CONFIDENCE_THRESHOLD=0.6

#=============================================================================
# DATA EXPORT & COMPLIANCE
#=============================================================================
# Never automatically export production data
AUTO_EXPORT_ENABLED=false
EXPORT_FREQUENCY=daily
EXPORT_PATH=./exports/

# Archive old data periodically
DATA_RETENTION_DAYS=365
DATA_ARCHIVAL_ENABLED=true
DATA_ARCHIVE_PATH=./archives/

#=============================================================================
# BACKUP & DISASTER RECOVERY
#=============================================================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_TIME=02:00
BACKUP_PATH=./backups/
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true

# S3 for backup storage (optional but recommended)
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=hft-backups
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
BACKUP_S3_SECRET_KEY=YOUR_AWS_SECRET_KEY

#=============================================================================
# PRODUCTION VPS DEPLOYMENT
#=============================================================================
# For Docker deployment
DOCKER_NETWORK=hft-network
DOCKER_REGISTRY=docker.io

# SSL/TLS Certificates
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/hft-trading.crt
SSL_KEY_PATH=/etc/ssl/private/hft-trading.key

# HTTPS/Reverse Proxy
REVERSE_PROXY_ENABLED=true
REVERSE_PROXY_URL=https://your-domain.com

#=============================================================================
# DEVELOPMENT/STAGING ONLY - DO NOT USE IN PRODUCTION
#=============================================================================
# DELETE THESE IN PRODUCTION ENVIRONMENT

# Mock Mode (for testing without real blockchain)
JUPITER_MOCK_ENABLED=false
HELIUS_MOCK_ENABLED=false

# Telegram Bot (optional - for alerts)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

#=============================================================================
# SECURITY CHECKLIST FOR PRODUCTION DEPLOYMENT
#=============================================================================
# ✓ Change all passwords to strong random values
# ✓ Generate new JWT_SECRET and API_KEY_SECRET
# ✓ Use environment-specific values (production/staging/development)
# ✓ Store secrets in secure vault (AWS Secrets Manager, HashiCorp Vault, etc.)
# ✓ Enable database SSL/TLS
# ✓ Enable HTTPS/TLS for API
# ✓ Set up firewall rules to restrict access
# ✓ Enable rate limiting and DDoS protection
# ✓ Set up monitoring and alerting
# ✓ Enable automated backups with encryption
# ✓ Rotate credentials regularly
# ✓ Use dedicated service accounts with minimal permissions
# ✓ Enable audit logging for all sensitive operations
# ✓ Implement request signing for API calls
# ✓ Use VPN or bastion host for VPS access
