# Copy this file to .env and fill in the values.
# Never commit real secrets to version control.

# Application
NODE_ENV=development
PORT=3001
WS_PORT=3002
ALLOWED_ORIGINS=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hft_trading
DB_USER=hft_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_MAX_CONNECTIONS=20
DATABASE_URL=postgres://hft_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/hft_trading

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Solana / Trading integrations
RPC_URL=https://api.mainnet-beta.solana.com
JUPITER_API_URL=https://quote-api.jup.ag
JUPITER_MOCK_ENABLED=false
HELIUS_API_KEY=
HELIUS_WATCH_ADDRESSES=

# Authentication / Security
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ENCRYPTION_KEY=CHANGE_ME_LONG_RANDOM_KEY
MASTER_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX_KEY
WEBHOOK_SIGNATURE_SECRET=CHANGE_ME_SECRET
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com

# Katana Engine
KATANA_ENABLED=true
KATANA_TERMINAL_MODE=false
KATANA_MAX_CONCURRENT_TRADES=5
KATANA_MIN_LIQUIDITY_SOL=5
KATANA_MAX_SLIPPAGE=0.3
KATANA_PRIORITY_FEE_LAMPORTS=100000
KATANA_AUTO_BUY_ENABLED=true
KATANA_JITO_ENABLED=false
KATANA_JITO_TIP=10000
KATANA_STOP_LOSS_ENABLED=true
KATANA_STOP_LOSS_PERCENT=20
KATANA_TRAILING_STOP_ENABLED=true
KATANA_TRAILING_STOP_PERCENT=10
KATANA_BREAKEVEN_ENABLED=true
KATANA_BREAKEVEN_PROFIT=50
KATANA_RISK_PROTECTION_ENABLED=true
KATANA_RISK_HONEYPOT_CHECK=true
KATANA_RISK_LIQUIDITY_CHECK=true
KATANA_RISK_DEV_CHECK=true
KATANA_RISK_MIN_LIQUIDITY=1
KATANA_RISK_MAX_DEV_PERCENT=20
KATANA_RISK_BLACKLIST=
KATANA_TP1_PROFIT=200
KATANA_TP1_SELL=30
KATANA_TP2_PROFIT=400
KATANA_TP2_SELL=30
KATANA_TP3_PROFIT=600
KATANA_TP3_SELL=100
KATANA_WS_PORT=3003
KATANA_WS_HEARTBEAT=30000
KATANA_WS_MAX_CLIENTS=100
KATANA_EXECUTOR_MAX_RETRIES=3
KATANA_EXECUTOR_RETRY_DELAY=1000
KATANA_EXECUTOR_PRIORITY_FEE=100000
KATANA_EXECUTOR_CONFIRMATION_TIMEOUT=30000
KATANA_EXECUTOR_MAX_CONCURRENT=10

# Risk limits
DAILY_LOSS_LIMIT_USD=10000
POSITION_SIZE_LIMIT_USD=50000
MAX_TRADES_PER_HOUR=100
COOLDOWN_PERIOD_MS=60000

# Email / Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password
# Note: analytics.service.js incorrectly reads process.env.SMTP_PASSWORD instead of SMTP_PASS.
# Set this to the same value as SMTP_PASS for analytics emails to work until that bug is fixed.
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@hftrading.com
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# Backups
BACKUP_RETENTION_DAYS=7

# Optional features
AI_SERVICE_ENABLED=false
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=

