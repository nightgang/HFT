{
  "name": "hft-solana-trading",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "start-backend": "cd backend && npm start",
    "start-frontend": "cd frontend && npm run dev",
    "cli": "node cli/katana-terminal.js",
    "katana": "node cli/katana-terminal.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3"
  },
  "overrides": {
    "uuid": "8.3.2"
  }
}
