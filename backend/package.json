{
  "name": "solana-trading-backend",
  "version": "1.0.0",
  "description": "Institutional-grade Solana trading system backend",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "dev": "nodemon index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "node db/migrate.js",
    "migrate:status": "node db/migrate.js status",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate",
    "backup": "node services/backup.service.js"
  },
  "dependencies": {
    "@solana/web3.js": "^1.68.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "bip39": "^3.1.0",
    "bs58": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.2.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "hdkey": "^0.6.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "libsodium-wrappers": "^0.7.13",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "prom-client": "^15.1.0",
    "redis": "^5.12.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^7.0.3",
    "winston": "^3.11.0",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^2.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "pm2": "^7.0.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3",
    "typescript": "^5.7.0"
  }
}
